{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "model": "opencode-go/glm-5.1",
  "formatter": true,
  "lsp": true,
  "default_agent": "build",
  "permission": {
    "read": {
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
      ".env*": "deny",
    },
    "edit": {
      "~/.ssh/**": "deny",
      "~/.gnupg/**": "deny",
    },
    "bash": {
      "rm *.env*": "deny"
    }
  },
  "instructions": [
    "./prompts/system.md",
  ],
}
